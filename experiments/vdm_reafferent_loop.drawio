        <mxCell id="IpgPxD4emPKAGwueZkEY-79" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;" value="" vertex="1">
          <mxGeometry height="284" width="488" x="1501" y="987" as="geometry" />
        </mxCell>
        <mxCell id="IpgPxD4emPKAGwueZkEY-80" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=24;" value="reafference/" vertex="1">
          <mxGeometry height="30" width="141" x="1523" y="1011" as="geometry" />
        </mxCell>
        <mxCell id="IpgPxD4emPKAGwueZkEY-81" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=20;" value="loop_basis.py" vertex="1">
          <mxGeometry height="55" width="205" x="1532" y="1069" as="geometry" />
        </mxCell>
        <mxCell id="IpgPxD4emPKAGwueZkEY-82" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=20;" value="loop_trace.py" vertex="1">
          <mxGeometry height="55" width="205" x="1747" y="1069" as="geometry" />
        </mxCell>
        <mxCell id="IpgPxD4emPKAGwueZkEY-83" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=20;" value="observation.py" vertex="1">
          <mxGeometry height="55" width="253" x="1532" y="1158" as="geometry" />
        </mxCell>
        <mxCell id="IpgPxD4emPKAGwueZkEY-85" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=24;" value="sensorimotor/" vertex="1">
          <mxGeometry height="30" width="60" x="1122" y="950" as="geometry" />
        </mxCell>
      </root>
