        <mxCell id="IpgPxD4emPKAGwueZkEY-78" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=20;" value="observer.py" vertex="1">
          <mxGeometry height="55" width="227" x="1112" y="1158" as="geometry" />
